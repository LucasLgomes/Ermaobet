# ==============================================================================
# Modelo de variaveis para o servico App no EasyPanel.
# NUNCA commite este arquivo preenchido com valores reais.
# Cole estes campos na aba "Environment" do servico e preencha os valores.
# ==============================================================================

# --- Aplicacao ---
APP_NAME=Ermaobet
APP_ENV=production
APP_KEY=                        # gere com: php artisan key:generate --show
APP_DEBUG=false
APP_DEMO=false
APP_URL=https://SEU_DOMINIO_AQUI
VITE_BASE_URL=/
SESSION_SECURE_COOKIE=true

# Painel admin (rota /dash por padrao; pode customizar)
ADMIN_PATH=dash

# --- Logs ---
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# --- Banco (MySQL do EasyPanel) ---
DB_CONNECTION=mysql
DB_HOST=aplicacoes_ermaobet
DB_PORT=3306
DB_DATABASE=ermaobet
DB_USERNAME=ermaobet
DB_PASSWORD=                    # usar senha forte (NAO usar "ermaobet" em producao)

# --- Sessao / cache / fila ---
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# --- JWT ---
JWT_SECRET=                     # gere com: php artisan jwt:secret --show
JWT_TTL=60

# --- Broadcast / WebSockets (opcional) ---
# Se nao for usar, deixe BROADCAST_DRIVER=null
BROADCAST_DRIVER=null
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Email (SMTP real do dominio) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# --- Login Google (opcional) ---
CONFIG_ENABLE_LOGIN_GOOGLE=false
GOOGLE_API_KEY=
GOOGLE_API_SECRET=
GOOGLE_REDIRECT=https://SEU_DOMINIO_AQUI/api/auth/login/google/callback

# --- Gateway Divpag / SuitPay (configurado pelo painel admin em /dash) ---
# Credenciais de gateway sao salvas no banco (tabela gateways), NAO aqui.
